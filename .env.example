# ======================================
# neubit.ai — PPE Detection · environment
# Copy to .env and adjust for your deployment.
# ======================================

# --- Server ---
# 0.0.0.0 = reachable on the machine's LAN IP (production). Use 127.0.0.1 for local-only.
PPE_HOST=0.0.0.0
PPE_PORT=5000
PPE_DEBUG=false
PPE_SECRET_KEY=change-this-in-production

# --- Detection / GPU ---
PPE_DEVICE=0            # 0 / cuda:0 for GPU, cpu for CPU
PPE_IMG_SIZE=1536       # higher = better recall on distant/crowded workers (slower)
PPE_FRAME_SKIP=2        # process every Nth frame (raise to 3 if live stream lags)

# --- Confidence gates ---
PPE_PERSON_CONF=0.35
PPE_PPE_CONF=0.50
PPE_NEG_CONF=0.50

# --- Temporal confirmation (suppresses flicker false-positives) ---
PPE_CONFIRM_WINDOW=8
PPE_CONFIRM_MIN_MISSING=6

# --- ReID ---
PPE_REID_ENABLED=true
PPE_REID_SIMILARITY_THRESHOLD=0.90
