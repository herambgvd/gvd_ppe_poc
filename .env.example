# ======================================
# neubit.ai — PPE Detection · environment
# Copy to .env and override only what you need. Every value below is the
# built-in default, so an empty .env behaves identically.
#   cp .env.example .env
# ======================================

# ---------- Server ----------
PPE_HOST=0.0.0.0              # 0.0.0.0 = reachable on the machine's LAN IP; 127.0.0.1 = local only
PPE_PORT=5000
PPE_DEBUG=false
PPE_SECRET_KEY=change-this-in-production

# ---------- Detection / GPU ----------
PPE_DEVICE=0                 # 0 / cuda:0 for GPU, cpu for CPU, auto to pick
PPE_IMG_SIZE=1536            # inference resolution; higher = better recall on distant/crowded workers (slower). Try 1280 for multi-cam.
PPE_FRAME_SKIP=2             # process every Nth frame; raise to 3-4 for many cameras / if live lags
PPE_CONF_THRESHOLD=0.25      # base model floor (real gating is per-class below)
PPE_IOU_THRESHOLD=0.55       # NMS IoU
PPE_MAX_DETECTIONS=300

# ---------- Per-class confidence gates ----------
PPE_PERSON_CONF=0.35         # lower = detect more (distant/occluded) people
PPE_PPE_CONF=0.50            # higher = fewer false PPE detections
PPE_NEG_CONF=0.50            # confidence for negative classes (no_helmet, ...)
PPE_MIN_PERSON_AREA=9000     # min person bbox area (px^2) before a violation is raised

# ---------- Temporal confirmation (kills flicker false-positives) ----------
# Flag PPE missing only when absent in >= MIN_MISSING of the last WINDOW frames.
# Faster response: lower MIN_MISSING (e.g. 2-3). More stable: raise both.
PPE_CONFIRM_WINDOW=8
PPE_CONFIRM_MIN_MISSING=6

# ---------- Event lifecycle ----------
PPE_PERSISTENCE_FRAMES=5     # confirmed frames before an event is created
PPE_RESOLVE_AFTER_SECONDS=4  # seconds a violation is unseen before it clears
PPE_EXPIRE_AFTER_SECONDS=120 # seconds before an event leaves memory
PPE_DUPLICATE_COOLDOWN_SECONDS=30

# ---------- Retention (auto-cleanup) ----------
PPE_EVENT_RETENTION_DAYS=2   # delete events + evidence images older than this (runs at startup + every 6h)

# ---------- Association ----------
PPE_ASSOCIATION_MIN_SCORE=0.28
PPE_TEMPORAL_ASSOC_BONUS=0.12

# ---------- Re-Identification (OSNet) ----------
PPE_REID_ENABLED=true
PPE_REID_SIMILARITY_THRESHOLD=0.90   # cosine cutoff; higher = stricter identity match
PPE_REID_MAX_AGE_SECONDS=12
PPE_REID_EMBED_REFRESH=15            # re-extract embedding every N frames for a tracked person

# ---------- Streaming / performance ----------
PPE_FRAME_BUFFER_SIZE=8
PPE_STREAM_FPS=12                    # target live MJPEG fps
PPE_JPEG_QUALITY=80                  # saved output video/frame quality
PPE_STREAM_PREVIEW_WIDTH=960         # live preview is downscaled to this width
PPE_STREAM_JPEG_QUALITY=70           # live preview compression (lighter = smoother)
PPE_CAPTURE_RECONNECT_SECONDS=5      # RTSP reconnect delay

# ======================================
# 7-CAMERA PROFILE (site deployment, e.g. SMCC)
# ======================================
# Each camera runs its OWN detector + tracker (7 model instances). On a 16 GB GPU
# keep IMG_SIZE at the proven 1536 and pace the pipelines with FRAME_SKIP instead:
#   7 cams x ~4-6 processed fps x ~12 ms  ≈  35-50% GPU.
# Uncomment to apply:
#PPE_FRAME_SKIP=3            # every 3rd frame per camera (raise to 4 if GPU/CPU saturates)
#PPE_STREAM_FPS=10           # slightly lower MJPEG poll rate for 7 concurrent feeds
#PPE_STREAM_PREVIEW_WIDTH=800 # lighter previews for a 7-feed wall page
#
# Camera URLs: when a vizor/go2rtc restream runs on the same machine, prefer
#   rtsp://127.0.0.1:8554/<camera-uuid>
# so each PHYSICAL camera keeps a single upstream RTSP session (the restream fans
# out to this app + anything else). Fall back to the camera's direct RTSP URL if
# go2rtc is not running. Use the main stream (not _sub) for PPE accuracy.
#
# Fallback knobs if a 7-cam box still lags: PPE_FRAME_SKIP=4, PPE_IMG_SIZE=1280,
# or point individual far-view cameras at their _sub stream.
